# Copy this file to .env and fill in your real values.
# .env is looked for in this same folder (next to main.py).

# Meta (Facebook) Marketing API
# 1. Use an existing Facebook Developer App (or create one) with the
#    "Marketing API" product added.
# 2. Generate a token with the ads_read permission for an ad account
#    you personally administer (Graph API Explorer, then extend it to
#    a long-lived token -- it lasts ~60 days, re-generate when it expires).
FB_ACCESS_TOKEN=your_long_lived_access_token_here

# Your ad account ID, including the "act_" prefix.
# Found in Meta Ads Manager -> Account overview, or in the URL.
FB_AD_ACCOUNT_ID=act_XXXXXXXXXXXXX

# Google Gemini API (optional)
# If set, gemini-3.5-flash becomes selectable alongside LM Studio models.
# Get a free API key at: https://aistudio.google.com/apikey
# GEMINI_API_KEY=your_gemini_api_key_here
